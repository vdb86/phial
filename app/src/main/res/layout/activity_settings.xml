<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/windowBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="48dp">

        <!-- Toolbar -->
        <TextView
            android:id="@+id/toolbarTitle"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:gravity="center"
            android:text="Settings"
            android:textSize="18sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="?android:attr/textColorPrimary"
            android:background="?android:attr/colorBackground"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="56dp"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:text="← Back"
            android:textSize="15sp"
            android:clickable="true"
            android:focusable="true"
            android:textColor="?android:attr/textColorSecondary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <View
            android:id="@+id/dividerToolbar"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:background="?android:attr/listDivider"
            app:layout_constraintTop_toBottomOf="@id/toolbarTitle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- ── BRIGHTNESS ─────────────────────────────────── -->
        <TextView
            android:id="@+id/labelBrightness"
            style="@style/SectionLabel"
            android:layout_marginTop="28dp"
            android:text="BRIGHTNESS"
            app:layout_constraintTop_toBottomOf="@id/dividerToolbar"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardRemember"
            style="@style/SettingCard"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelBrightness"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:id="@+id/tvRememberTitle" style="@style/SettingTitle"
                android:text="Remember brightness"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/switchRemember"/>
            <Switch android:id="@+id/switchRemember" style="@style/SettingSwitch"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ── BEHAVIOUR ──────────────────────────────────── -->
        <TextView
            android:id="@+id/labelBehaviour"
            style="@style/SectionLabel"
            android:layout_marginTop="28dp"
            android:text="BEHAVIOUR"
            app:layout_constraintTop_toBottomOf="@id/cardRemember"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Fade in -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardFadeIn"
            style="@style/SettingCard"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/labelBehaviour"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:id="@+id/tvFadeInTitle" style="@style/SettingTitle"
                android:text="Fade in on open"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/switchFadeIn"/>
            <Switch android:id="@+id/switchFadeIn" style="@style/SettingSwitch"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Shake -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardShake"
            style="@style/SettingCard"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardFadeIn"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:id="@+id/tvShakeTitle" style="@style/SettingTitle"
                android:text="Shake for flashlight"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/switchShake"/>
            <Switch android:id="@+id/switchShake" style="@style/SettingSwitch"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Volume -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardVolume"
            style="@style/SettingCard"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardShake"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:id="@+id/tvVolumeTitle" style="@style/SettingTitle"
                android:text="Volume buttons control brightness"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/switchVolume"/>
            <Switch android:id="@+id/switchVolume" style="@style/SettingSwitch"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Auto-off -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardAutoOff"
            style="@style/SettingCard"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardVolume"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:id="@+id/tvAutoOffTitle" style="@style/SettingTitle"
                android:text="Auto-off timer"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/btnAutoOff"/>
            <TextView
                android:id="@+id/btnAutoOff"
                android:layout_width="80dp"
                android:layout_height="36dp"
                android:layout_marginEnd="16dp"
                android:gravity="center"
                android:background="@drawable/close_button_bg"
                android:textSize="14sp"
                android:clickable="true"
                android:focusable="true"
                android:textColor="?android:attr/textColorSecondary"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Dark mode -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardDarkMode"
            style="@style/SettingCard"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/cardAutoOff"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView android:id="@+id/tvDarkTitle" style="@style/SettingTitle"
                android:text="Dark mode"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toStartOf="@id/switchDarkMode"/>
            <Switch android:id="@+id/switchDarkMode" style="@style/SettingSwitch"
                app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ── COLOUR MODE ────────────────────────────────── -->
        <TextView
            android:id="@+id/labelColor"
            style="@style/SectionLabel"
            android:layout_marginTop="28dp"
            android:text="COLOUR MODE"
            app:layout_constraintTop_toBottomOf="@id/cardDarkMode"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardColor"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="?android:attr/colorBackground"
            android:elevation="1dp"
            android:layout_marginTop="8dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/labelColor"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <!-- Colour swatches row -->
            <LinearLayout
                android:id="@+id/colorRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <View android:id="@+id/btnColorWhite"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/color_swatch_white"
                    android:clickable="true" android:focusable="true"/>
                <View android:id="@+id/btnColorWarm"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/color_swatch_warm"
                    android:clickable="true" android:focusable="true"/>
                <View android:id="@+id/btnColorAmber"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/color_swatch_amber"
                    android:clickable="true" android:focusable="true"/>
                <View android:id="@+id/btnColorRed"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/color_swatch_red"
                    android:clickable="true" android:focusable="true"/>
                <View android:id="@+id/btnColorCustom"
                    android:layout_width="44dp" android:layout_height="44dp"
                    android:layout_margin="6dp"
                    android:background="@drawable/color_swatch_custom"
                    android:clickable="true" android:focusable="true"/>
            </LinearLayout>

            <!-- Labels row -->
            <LinearLayout
                android:id="@+id/colorLabelRow"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="4dp"
                app:layout_constraintTop_toBottomOf="@id/colorRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                    android:text="White" android:gravity="center" android:textSize="10sp"
                    android:textColor="?android:attr/textColorSecondary"/>
                <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                    android:text="Warm" android:gravity="center" android:textSize="10sp"
                    android:textColor="?android:attr/textColorSecondary"/>
                <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                    android:text="Amber" android:gravity="center" android:textSize="10sp"
                    android:textColor="?android:attr/textColorSecondary"/>
                <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                    android:text="Red" android:gravity="center" android:textSize="10sp"
                    android:textColor="?android:attr/textColorSecondary"/>
                <TextView android:layout_width="56dp" android:layout_height="wrap_content"
                    android:text="Custom" android:gravity="center" android:textSize="10sp"
                    android:textColor="?android:attr/textColorSecondary"/>
            </LinearLayout>

            <!-- Preview button -->
            <TextView
                android:id="@+id/btnPreviewColor"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:gravity="center"
                android:text="Preview"
                android:textSize="14sp"
                android:background="@drawable/close_button_bg"
                android:clickable="true"
                android:focusable="true"
                android:textColor="?android:attr/textColorSecondary"
                app:layout_constraintTop_toBottomOf="@id/colorLabelRow"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ── ABOUT ───────────────────────────────────────── -->
        <TextView
            android:id="@+id/labelAbout"
            style="@style/SectionLabel"
            android:layout_marginTop="28dp"
            android:text="ABOUT"
            app:layout_constraintTop_toBottomOf="@id/cardColor"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cardAbout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:background="?android:attr/colorBackground"
            android:elevation="1dp"
            android:layout_marginTop="8dp"
            android:paddingStart="16dp"
            android:paddingTop="20dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp"
            app:layout_constraintTop_toBottomOf="@id/labelAbout"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/textQuote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="&#8220;May it be a light to you in dark places,\nwhen all other lights go out.&#8221;"
                android:textSize="15sp"
                android:lineSpacingMultiplier="1.4"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:textColor="?android:attr/textColorPrimary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/textQuoteAttrib"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="— Galadriel, The Fellowship of the Ring"
                android:textSize="13sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:textColor="?android:attr/textColorSecondary"
                app:layout_constraintTop_toBottomOf="@id/textQuote"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <View
                android:id="@+id/dividerAbout"
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="?android:attr/listDivider"
                app:layout_constraintTop_toBottomOf="@id/textQuoteAttrib"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/textDedication"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="Dedicated to my wife Ana."
                android:textSize="15sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:gravity="center"
                android:textColor="?android:attr/textColorPrimary"
                app:layout_constraintTop_toBottomOf="@id/dividerAbout"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
