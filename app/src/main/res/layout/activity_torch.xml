<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:clickable="true"
    android:focusable="true"
    android:fitsSystemWindows="false">

    <!-- Settings cog - top right -->
    <ImageView
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="48dp"
        android:layout_marginEnd="16dp"
        android:padding="12dp"
        android:src="@drawable/ic_cog"
        android:alpha="0.4"
        android:clickable="true"
        android:focusable="true"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Flashlight mode icon -->
    <TextView
        android:id="@+id/flashIcon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚡"
        android:textSize="64sp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/shakeHint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Shake hint (shown in both modes, different text) -->
    <TextView
        android:id="@+id/shakeHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Shake to switch to flashlight"
        android:textColor="#66000000"
        android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@id/labelBrightness"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Brightness label -->
    <TextView
        android:id="@+id/labelBrightness"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Brightness"
        android:textColor="#99000000"
        android:textSize="13sp"
        android:letterSpacing="0.12"
        android:fontFamily="sans-serif-light"
        app:layout_constraintBottom_toTopOf="@id/seekBar"
        app:layout_constraintEnd_toEndOf="@id/seekBar"
        app:layout_constraintStart_toStartOf="@id/seekBar"/>

    <!-- Brightness SeekBar -->
    <SeekBar
        android:id="@+id/seekBar"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="88dp"
        android:max="100"
        android:progress="100"
        android:progressTint="#AAAAAA"
        android:thumb="@drawable/slider_thumb"
        android:progressBackgroundTint="#DDDDDD"
        app:layout_constraintBottom_toTopOf="@id/btnClose"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Close button -->
    <TextView
        android:id="@+id/btnClose"
        android:layout_width="120dp"
        android:layout_height="44dp"
        android:layout_marginBottom="48dp"
        android:background="@drawable/close_button_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="✕  Close"
        android:textColor="#777777"
        android:textSize="15sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
