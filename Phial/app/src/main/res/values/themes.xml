<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- DayNight base — responds to AppCompatDelegate night mode -->
    <style name="Theme.Phial" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">?android:attr/colorBackground</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#00000000</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>

    <!-- Settings screen: normal, respects status and nav bars -->
    <style name="Theme.Phial.Settings" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="android:windowBackground">?android:attr/colorBackground</item>
        <item name="android:fitsSystemWindows">true</item>
    </style>

    <!-- Torch screen: truly fullscreen, draws under status + nav bars -->
    <style name="Theme.Phial.Fullscreen" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:statusBarColor">#00000000</item>
        <item name="android:navigationBarColor">#00000000</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowBackground">#FFFFFF</item>
    </style>

</resources>
